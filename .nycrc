{
  "extends": "@istanbuljs/nyc-config-typescript",
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "**/*.d.ts",
    "node_modules/**/*.*",
    "coverage/**/*.*",
    "tests/**/*.*",
    "dist/**/*.*"
  ],
  "reporter": [
    "html",
    "text",
    "text-summary"
  ],
  "report-dir": "coverage",
  "all": true,
  "check-coverage": false
}
